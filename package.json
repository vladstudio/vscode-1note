{
  "name": "1note",
  "displayName": "1note",
  "description": "Quick access to your ~/.1note.md",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladstudio/vscode-1note"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon/1note-color.png",
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "1note.open",
        "title": "Open 1note"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -watch"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
